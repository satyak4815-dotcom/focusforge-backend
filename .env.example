# ─────────────────────────────────────────────────────────────────────────────
# FocusForge Backend — Environment Variable Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` for local development.
# On Render, set these values directly in the Environment Variables dashboard.
# NEVER commit your real `.env` file to Git.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Get this from: MongoDB Atlas → Cluster → Connect → Drivers
MONGO_URI=your_mongodb_connection_string_here

# Secret key for signing JWT tokens — use a long, random string in production
JWT_SECRET=your_super_secret_jwt_key_here

# Local dev port (Render overrides this automatically with its own PORT)
PORT=3000

# Your published Chrome Extension ID (found in chrome://extensions)
# Add this to the allowedOrigins array in server.js before deploying
EXTENSION_ID=YOUR_EXTENSION_ID_HERE
